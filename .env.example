# Copie para .env na MESMA pasta que docker-compose.yml e preencha a chave:
#   cp .env.example .env
# O backend NÃO lê .env.example — só .env (e o Compose usa .env para variáveis).
# Nunca commite .env nem cole chaves reais neste arquivo de exemplo.

# OpenProject (instância fora deste compose)
# Se o backend rodar em Docker e o OpenProject na sua máquina (ex.: porta 8080), NÃO use
# localhost no .env — o backend reescreve para host.docker.internal automaticamente.
# Além disso, o OpenProject precisa aceitar conexões vindas do Docker: escute em 0.0.0.0:8080,
# não só 127.0.0.1; caso contrário verá ECONNREFUSED a partir do container.
# No Linux, alternativa sem mudar o bind do OpenProject:
#   docker compose -f docker-compose.yml -f docker-compose.host.yml up --build
# (backend em network_mode: host; prefira OPENPROJECT_BASE_URL=http://localhost:8080 nesse modo.)
OPENPROJECT_BASE_URL=http://host.docker.internal:8080
# Se rodar o backend com "node" direto no host (sem Docker), aí sim pode ser:
# OPENPROJECT_BASE_URL=http://localhost:8080
# Atenção ao digitar o host: "locahost" (sem o segundo "l") quebra o DNS.
OPENPROJECT_API_KEY=your_api_key_here
OPENPROJECT_AUTH_MODE=basic
OPENPROJECT_PROJECT_IDENTIFIER=nome-do-seu-projeto

# Tipo padrão de work package (ID numérico no OpenProject) quando não houver mapeamento por linha
OPENPROJECT_DEFAULT_TYPE_ID=1

# Mapeamento opcional: tipo no CSV -> ID numérico do tipo no OpenProject (JSON)
# Exemplo: {"Epic":1,"Feature":2,"Product Backlog Item":3,"Task":4}
OPENPROJECT_TYPE_MAP_JSON={}

# A linha 1 do CSV define os nomes das colunas; cada variável abaixo é o nome preferido
# (casamento exato ou só maiúsculas/minúsculas; há aliases para export comum do Azure DevOps).
# Export hierárquico com Title 1, Title 2, … e sem coluna Parent: título e pai são derivados
# automaticamente pela ordem das linhas e pela profundidade (coluna não vazia mais à direita).
CSV_COLUMN_ID=ID
CSV_COLUMN_TITLE=Title
CSV_COLUMN_WORK_ITEM_TYPE=Work Item Type
CSV_COLUMN_PARENT=Parent

# Banco (valores padrão alinhados ao docker-compose.yml)
DATABASE_URL=postgres://importer:importer@db:5432/importer

# API
PORT=3001
NODE_ENV=development

# Opcional — só build do frontend: se o SPA for servido sem proxy /api, aponte para o backend
# VITE_API_BASE=http://localhost:3001

# true = valida e simula importação sem chamar criação na API
DRY_RUN=false

LOG_LEVEL=info
